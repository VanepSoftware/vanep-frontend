# Base URL do backend Vanep (Spring Authorization Server), SEM sufixo /api.
# Dev: http://localhost:8080
AUTH_URL=http://localhost:8080

# Cliente OAuth público registrado no backend (PKCE, sem secret).
# Deve bater com VANEP_OAUTH_CLIENT_ID no vanep-api-java.
AUTH_OAUTH_CLIENT_ID=vanep-frontend

# Segredo para assinar o JWT de sessão do NextAuth: openssl rand -base64 32
AUTH_SECRET=

# URL pública deste frontend (NextAuth). O callback é ${NEXTAUTH_URL}/api/auth/callback/vanep,
# que precisa estar nos redirect URIs do cliente no backend (VANEP_OAUTH_REDIRECT_URIS).
NEXTAUTH_URL=http://localhost:3000
